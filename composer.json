{
    "name": "alaszi/smartrelay",
    "description": "SmartRelay - Regional alert hub and CMMS-lite maintenance system",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "SmartRelay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SmartRelay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testdox",
        "test-coverage": "phpunit --coverage-text",
        "analyse": "phpstan analyse src --level=5"
    }
}
