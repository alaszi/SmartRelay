# SmartRelay Environment Configuration
# Copy this file to .env and fill in real values (never commit .env!)

# === Telegram Notifications ===
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=-100your_channel_id   # comma-separated for multiple channels

# === Database (future use) ===
DB_HOST=localhost
DB_NAME=smartrelay
DB_USER=smartrelay
DB_PASS=

# === App ===
APP_ENV=production   # production | development
APP_DEBUG=false
